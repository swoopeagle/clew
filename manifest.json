{
  "display_information": {
    "name": "clew"
  },
  "features": {
    "agent_view": {
      "agent_description": "I find real, sourced grant and funder prospects that fit your organization, screen them for fit, and hand your team a shortlist to approve or pass on \u2014 built for small nonprofit teams without dedicated grant-research staff.",
      "suggested_prompts": [
        {
          "title": "Find grants for us",
          "message": "Find grants and foundations that fit our org profile."
        },
        {
          "title": "Set up our org profile",
          "message": "Help me set up our org profile so you can screen grants for fit."
        }
      ]
    },
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "clew",
      "always_online": true
    }
  },
  "oauth_config": {
    "redirect_urls": [
      "https://ngrok-free.app/slack/oauth_redirect"
    ],
    "scopes": {
      "user": [
        "search:read",
        "channels:history",
        "channels:read",
        "groups:history",
        "groups:read",
        "im:history",
        "mpim:history",
        "users:read",
        "search:read.public",
        "search:read.private",
        "search:read.mpim",
        "search:read.im",
        "search:read.files",
        "search:read.users",
        "chat:write",
        "canvases:read",
        "canvases:write",
        "users:read.email"
      ],
      "bot": [
        "app_mentions:read",
        "channels:history",
        "chat:write",
        "groups:history",
        "im:history",
        "im:read",
        "im:write",
        "reactions:write",
        "reactions:read",
        "users:read",
        "assistant:write",
        "channels:manage",
        "channels:read",
        "pins:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://ngrok-free.app/slack/events",
      "bot_events": [
        "app_home_opened",
        "app_mention",
        "message.channels",
        "message.groups",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://ngrok-free.app/slack/events"
    },
    "is_mcp_enabled": true,
    "org_deploy_enabled": true,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
